# mailgunfire self-host config — EXAMPLE / template. Fill in your own values.
# Use it via:  docker compose --env-file mailgunfire.env up -d
# (or rename this file to `.env`, which `docker compose up` reads automatically).

# ── Required: your Mailgun account ──
# Your Mailgun sending domain (e.g. mg.example.com).
DOMAIN=
# Your Mailgun Sending API key (Mailgun dashboard → Sending → API keys).
# Treat as a secret — do not commit your .env.
KEY=

# ── Optional ──
# Default "from" localpart; the address becomes FROM@DOMAIN.
FROM=noreply
# Default display name shown to recipients.
DISPLAY=
# Set to 1 if your Mailgun account is on the EU region.
EU=
# Set a passphrase to password-protect the app (lock screen). Leave empty = open.
LOCK=
# Sent-record retention in seconds (e.g. 2592000 = 30 days). Empty = keep forever.
TTL=
# Where Redis (mail metadata + attachment slabs) and the optional Ollama (AI
# models) persist ON THE HOST. Default ./data → ./data/redis + ./data/ollama. The
# dirs are auto-created and the images set their own permissions on first start —
# no host-side mkdir/chown. Back up by copying this folder; absolute path = elsewhere.
DATA_DIR=./data
# Host port to expose the UI on (default 8080 → http://localhost:8080).
PORT=8080

# ── AI compose (OPTIONAL) ──
# Leave OLLAMA empty to disable AI entirely (the AI buttons won't appear).
# To enable, point it at any Ollama API endpoint:
#   • your own existing Ollama:   OLLAMA=http://your-host:11434
#   • the bundled one:            OLLAMA=http://ollama:11434
#       (start it with `docker compose --profile ai up -d`, then pull a model:
#        `docker compose exec ollama ollama pull llama3.1`)
OLLAMA=
# Default model name for AI compose (must be installed in your Ollama). The UI
# also lets you pick from whatever models that Ollama has. Empty = first available.
MODEL=
