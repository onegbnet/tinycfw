# shurl self-host config — EXAMPLE / template. Fill in your own values.
# Use it via:  docker compose --env-file shurl.env up -d
# (or rename this file to `.env`, which `docker compose up` reads automatically).
# Treat this file as secret once filled in — do not commit your real .env.

# ── Admin + limits ──
# Admin password — enables the admin UI + API (list/delete/purge). Generate:
#   openssl rand -hex 16
ADMIN=
# Per-window create rate limit (number of new links per client window).
LIMIT=100
# Cron token — drives the background blob-reclaim sweep (POST /_cron). The
# bundled reclaim ticker uses it to delete the file bytes of expired links.
# Set it to any random string, else those blobs are never reclaimed:
#   openssl rand -hex 16
CRON=

# ── Pointer store (required) — short-link + file metadata ──
# Redis URL. Default points at the bundled redis service. Password in the URL:
#   redis://:yourpassword@redis:6379
DATA=redis://redis:6379
# Optional key prefix (namespacing a shared Redis).
PREFIX=

# ── Blob store (required for FILE SHARING) ──
# S3 URL of the object store that holds uploaded file bytes:
#   http://<accessKey>:<secretKey>@<host>:<port>/<bucket>
# Default matches the bundled MinIO creds + bucket below. For Cloudflare R2 via
# its S3 API instead, use the R2 S3 endpoint + an R2 access key/secret (https),
# and drop the minio / minio-init services from the compose file.
BOS=http://shurl:shurlsecret@minio:9000/shurl
# Bundled MinIO root creds + bucket name (used by the minio + minio-init
# services). If you change any of these, update BOS to match.
MINIO_USER=shurl
MINIO_PASS=shurlsecret
BUCKET=shurl

# ── Optional ──
# Host port to expose the UI on (default 8080 → http://localhost:8080).
PORT=8080
# Public base URL used to build returned short links (e.g. https://go.example.com).
# Empty = derive from the incoming request origin.
BASE=
