# mixssl self-host config — EXAMPLE / template. Fill in your own values.
# Use it via:  docker compose --env-file mixssl.env up -d
# (or rename this file to `.env`, which `docker compose up` reads automatically).
# Treat this file as secret once filled in — do not commit your real .env.

# ── Required ──
# Credential-encryption key: 32 random bytes, base64. Encrypts the DNS-provider
# and CA credentials stored in the database. Generate once:
#   openssl rand -base64 32
MASTER=
# Cron token: any random string. The bundled ticker sends it as a bearer to
# POST /_cron so background certificate jobs + auto-renewals actually run. Leave
# it empty and nothing auto-ticks. Generate one:  openssl rand -hex 16
CRON=

# ── Database ──
# libSQL/sqld HTTP URL. Default points at the bundled sqld service in the compose
# file; change it only if you run your own. (A token can ride in the URL userinfo:
# http://<token>@host:8080 — not needed for the bundled, private-network sqld.)
DATA=http://sqld:8080

# ── Optional ──
# Set a passphrase to password-protect the app (lock screen). Leave empty = open.
LOCK=
# Where the sqld database (certificates + ACME accounts) persists ON THE HOST.
# Default ./data → ./data/sqld. The dir is auto-created on first start — no
# host-side mkdir/chown. Back up by copying this folder; absolute path = elsewhere.
DATA_DIR=./data
# Host port to expose the UI on (default 8080 → http://localhost:8080).
PORT=8080

# ── Note: NO ZeroSSL EAB needed when self-hosting ──
# The built-in CA here is Let's Encrypt — auto-registered on first run with NO
# credentials (LE is reachable from your own network, unlike from Cloudflare
# Workers). ZEK / ZEH (the ZeroSSL EAB) are a Cloudflare-only concept and DO NOT
# EXIST in the container. ZeroSSL / Google Trust Services can still be added by
# hand in the UI if you want them as extra CAs.
